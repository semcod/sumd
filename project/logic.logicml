imports:
  stdlib: [datetime, abc.{ABC,abstractmethod}, dataclasses.{dataclass,field}, typing.{Any,Dict,List,Optional}]
  third_party: [uuid, events.EventStore]

Query:
  doc: "Base query class for CQRS pattern."

QueryHandler:
  doc: "Base query handler interface."
  bases: [ABC]
  abstract: true
  methods:
    handle:
      sig: async (query:Query) -> Any
      does: "Handle a query and return results."
      decorators: [abstractmethod]
    can_handle:
      sig: (query_type:str) -> bool
      does: "Check if this handler can handle the given query type."
      decorators: [abstractmethod]

QueryBus:
  doc: "Query bus for dispatching queries to appropriate handlers."
  attrs:
    event_store: EventStore
  methods:
    __init__:
      sig: (event_store:EventStore) -> None
      does: "creates"
    register_handler:
      sig: (query_type:str, handler:QueryHandler) -> None
      does: "Register a query handler for a specific query type."
    dispatch:
      sig: async (query:Query) -> Any
      does: "Dispatch a query to the appropriate handler."
      edge: "error → raise ValueError"

GetSumdDocument:
  doc: "Query to get a SUMD document."
  bases: [Query]

ListSumdSections:
  doc: "Query to list sections in a SUMD document."
  bases: [Query]

GetSumdSection:
