      does: "Handle get project info query."
    _handle_get_event_history:
      sig: async (query:Query) -> Dict[str, Any]
      does: "Handle get event history query."
    _handle_get_all_events:
      sig: async (query:Query) -> Dict[str, Any]
      does: "Handle get all events query."
    _handle_search_documents:
      sig: async (query:Query) -> Dict[str, Any]
