      does: "All sections have been migrated to Section classes."
    _assemble:
      sig: (ctx:RenderContext, profile:str) -> str
      does: "Assemble all section lines into final markdown."
    run:
      sig: (profile:str='rich', return_sources:bool=False) -> str | tuple[str, list[str]]
      does: "Run the full pipeline and return rendered SUMD content."

functions:
