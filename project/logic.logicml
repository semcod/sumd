    does: "Test the zero-dependency pure-Python Prolog SLD engine on basic facts."
  test_architectural_validation_missing_file:
    sig: (tmp_path) -> None
    does: "Test Layer 3 consistency: declared file is missing from filesystem."
    side: "Writes data"
  test_architectural_validation_aligned:
    sig: (tmp_path) -> None
    does: "Test that an entirely consistent project reports no errors."
    side: "Writes data"
  test_architectural_validation_missing_automation:
    sig: (tmp_path) -> None
    does: "Test Layer 3: workflow exists but Makefile / Taskfile has no matching automat..."
    side: "Writes data"
  test_architectural_validation_missing_gate:
    sig: (tmp_path) -> None
    does: "Test Layer 2: quality workflow exists but no matching pyqual gate is declared."
    side: "Writes data"

