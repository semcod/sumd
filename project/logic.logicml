# aggregates.py | AggregateRoot, EntityState, Entity +3 | 221 lines

imports:
  stdlib: [abc.{ABC,abstractmethod}, dataclasses.{dataclass,field}, typing.{Any,Dict,List,Optional}]
  third_party: [events.{Event,EventStore}]

AggregateRoot:
  doc: "Base aggregate root for event sourcing."
  bases: [ABC]
  abstract: true
  attrs:
    aggregate_id: str
  methods:
    __init__:
      sig: (aggregate_id:str) -> None
      does: "creates"
    aggregate_id:
      sig: @property () -> str
      does: "Get the aggregate ID."
      decorators: [property]
    version:
      sig: @property () -> int
      does: "Get the current version of the aggregate."
      decorators: [property]
    uncommitted_events:
      sig: @property () -> List[Event]
      does: "Get uncommitted events."
      decorators: [property]
    set_event_store:
      sig: (event_store:EventStore) -> None
      does: "Set the event store for this aggregate."
      side: "Sets value"
    apply_event:
      sig: (event:Event) -> None
      does: "Apply an event to the aggregate."
      edge: "error → raise ValueError"
      side: "Modifies list"
    mark_events_as_committed:
      sig: () -> None
      does: "Mark all uncommitted events as committed."
      side: "Clears collection"
    load_from_history:
      sig: (events:List[Event]) -> None
      does: "Load aggregate state from event history."
      edge: "error → raise ValueError"
    _when:
      sig: (event:Event) -> None
      does: "Apply event-specific logic to update aggregate state."
      decorators: [abstractmethod]
    commit:
      sig: () -> None
      does: "Commit uncommitted events to the event store."
      edge: "error → raise ValueError"
      side: "Saves data"
    get_state:
      sig: () -> Dict[str, Any]
      does: "Get the current state of the aggregate."

EntityState:
  doc: "Base entity state for aggregates."

Entity:
  doc: "Base entity for domain objects."
  bases: [ABC]
  abstract: true
  attrs:
    entity_id: str
  methods:
    __init__:
      sig: (entity_id:str) -> None
      does: "creates"
    id:
      sig: @property () -> str
      does: "Get the entity ID."
      decorators: [property]
    domain_events:
      sig: @property () -> List[Event]
      does: "Get domain events."
      decorators: [property]
    add_domain_event:
      sig: (event:Event) -> None
      does: "Add a domain event."
      side: "Adds element"
    clear_domain_events:
      sig: () -> None
      does: "Clear domain events."
      side: "Clears collection"
    get_state:
      sig: () -> Dict[str, Any]
      does: "Get the current state of the entity."

ValueObject:
  doc: "Base value object."
  bases: [ABC]
  abstract: true
  methods:
    __eq__:
      sig: (other:object) -> bool
      does: "Value objects are equal if their attributes are equal."
    __hash__:
      sig: () -> int
      does: "Value objects should be hashable."
    get_state:
      sig: () -> Dict[str, Any]
      does: "Get the current state of the value object."

Repository:
  doc: "Base repository for aggregates."
  bases: [ABC]
  abstract: true
  methods:
    get_by_id:
      sig: async (aggregate_id:str) -> Optional[AggregateRoot]
      does: "Get an aggregate by its ID."
      decorators: [abstractmethod]
    save:
      sig: async (aggregate:AggregateRoot) -> None
      does: "Save an aggregate."
      side: "Saves data"
      decorators: [abstractmethod]
    delete:
      sig: async (aggregate_id:str) -> None
      does: "Delete an aggregate."
      side: "Deletes data"
      decorators: [abstractmethod]

EventSourcedRepository:
  doc: "Event-sourced repository implementation."
  bases: [Repository]
  attrs:
    event_store: EventStore
    aggregate_factory: Any
  methods:
    __init__:
      sig: (event_store:EventStore, aggregate_factory) -> None
      does: "creates"
    get_by_id:
      sig: async (aggregate_id:str) -> Optional[AggregateRoot]
      does: "Get an aggregate by its ID from event store."
      side: "Sets value"
    save:
      sig: async (aggregate:AggregateRoot) -> None
      does: "Save an aggregate to the event store."
      side: "Saves data"
    delete:
      sig: async (aggregate_id:str) -> None
      does: "Delete an aggregate (remove from cache)."
      side: "Deletes data"
    clear_cache:
      sig: () -> None
      does: "Clear the repository cache."
      side: "Clears collection"

# commands.py | Command, CommandHandler, CommandBus +9 | 266 lines

imports:
  stdlib: [datetime, abc.{ABC,abstractmethod}, dataclasses.{dataclass,field}, typing.{Any,Dict,List,Optional}]
  third_party: [uuid, events.{Event,EventStore}]

Command:
  doc: "Base command class for CQRS pattern."

CommandHandler:
  doc: "Base command handler interface."
  bases: [ABC]
  abstract: true
  methods:
    handle:
      sig: async (command:Command) -> List[Event]
      does: "Handle a command and return resulting events."
      decorators: [abstractmethod]
    can_handle:
      sig: (command_type:str) -> bool
      does: "Check if this handler can handle the given command type."
      decorators: [abstractmethod]

CommandBus:
  doc: "Command bus for dispatching commands to appropriate handl..."
  attrs:
    event_store: EventStore
  methods:
    __init__:
      sig: (event_store:EventStore) -> None
      does: "creates"
    register_handler:
      sig: (command_type:str, handler:CommandHandler) -> None
      does: "Register a command handler for a specific command type."
    dispatch:
      sig: async (command:Command) -> List[Event]
      does: "Dispatch a command to the appropriate handler."
      edge: "error → raise ValueError"
      side: "Saves data"

CreateSumdDocument:
  doc: "Command to create a new SUMD document."
  bases: [Command]

UpdateSumdDocument:
  doc: "Command to update an existing SUMD document."
  bases: [Command]

AddSumdSection:
  doc: "Command to add a section to a SUMD document."
  bases: [Command]

RemoveSumdSection:
  doc: "Command to remove a section from a SUMD document."
  bases: [Command]

ValidateSumdDocument:
  doc: "Command to validate a SUMD document."
  bases: [Command]

ScanProject:
  doc: "Command to scan a project and generate SUMD."
  bases: [Command]

GenerateMap:
  doc: "Command to generate project map."
  bases: [Command]

ExecuteDslCommand:
  doc: "Command to execute DSL command."
  bases: [Command]

SumdCommandHandler:
  doc: "Base handler for SUMD commands."
  bases: [CommandHandler]
  attrs:
    event_store: EventStore
  methods:
    __init__:
      sig: (event_store:EventStore) -> None
      does: "creates"
    can_handle:
      sig: (command_type:str) -> bool
      does: "Check if this handler can handle SUMD commands."
    handle:
      sig: async (command:Command) -> List[Event]
