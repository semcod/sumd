imports:
  stdlib: [sys, pathlib.Path, typing.{Any,Dict,List,Optional}]
  third_party: [asyncio, readline, commands.{DSLCommandRegistry,create_builtin_registry}, engine.{DSLContext,DSLEngine}, parser.parse_dsl]

DSLShell:
  doc: "Interactive shell for SUMD DSL."
  attrs:
    engine: Optional[DSLEngine]=None
    command_registry: Optional[DSLCommandRegistry]=None
    working_directory: Optional[Path]=None
  methods:
    __init__:
      sig: (engine:Optional[DSLEngine]=None, command_registry:Optional[DSLCommandRegistry]=None, working_directory:Optional[Path]=None) -> None
      does: "creates"
      side: "Sets value"
    _setup_readline:
      sig: () -> None
      does: "Setup readline for command history and completion."
      side: "Sets value"
    _completer:
      sig: (text:str, state:int) -> Optional[str]
      does: "Tab completion for DSL commands."
      side: "Modifies list"
    _register_commands:
      sig: () -> None
      does: "Register command functions in the DSL context."
    run:
      sig: async () -> None
      does: "Run the interactive shell."
      side: "Writes data"
    _get_prompt:
      sig: () -> str
      does: "Get the current prompt."
    _handle_shell_command:
      sig: async (command:str) -> None
      does: "Handle shell commands (prefixed with !)."
    _execute_line:
      sig: async (line:str) -> None
      does: "Execute a DSL line."
      side: "Modifies list"
    execute_script:
      sig: async (script_path:Path) -> None
      does: "Execute a DSL script file."
      edge: "error → raise ValueError"
    execute_command:
      sig: async (command:str) -> Any
      does: "Execute a single DSL command."
      edge: "error → raise ValueError"

DSLShellServer:
  doc: "Server for DSL shell operations (for MCP integration)."
  attrs:
    working_directory: Optional[Path]=None
  methods:
    __init__:
      sig: (working_directory:Optional[Path]=None) -> None
      does: "creates"
    execute_dsl:
      sig: async (dsl_expression:str, context_vars:Optional[Dict[str,Any]]=None) -> Dict[str, Any]
      does: "Execute DSL expression and return result."
      side: "Sets value"
    get_shell_info:
      sig: async () -> Dict[str, Any]
      does: "Get shell information."

functions:
  main:
    sig: async () -> None
    does: "Main entry point for DSL shell."
    side: "Adds element"

