  bases: [BaseModel]
  attrs:
    name: str
    data_type: DSLDataType
    required: bool
    default: Optional[Any]
    description: Optional[str]
    validation: Optional[Dict[str, Any]]

DSLCommandSchema:
  doc: "DSL command schema definition."
  bases: [BaseModel]
  attrs:
    name: str
    command_type: DSLCommandType
    action_type: DSLActionType
    description: str
    parameters: List[DSLParameter]
    returns: DSLDataType
    examples: List[str]
    aliases: List[str]

DSLProjectSchema:
  doc: "DSL project schema definition."
  bases: [BaseModel]
  attrs:
    name: str
    version: str
    description: Optional[str]
    created_at: datetime
    updated_at: datetime
    root_path: Path
    config_files: List[str]
    source_dirs: List[str]
    ignore_patterns: List[str]
    commands: List[DSLCommandSchema]

DSLExpression:
  doc: "DSL expression model."
  bases: [BaseModel]
  attrs:
    type: str
    value: Any
    children: List["DSLExpression"]
    metadata: Dict[str, Any]

DSLStatement:
  doc: "DSL statement model."
  bases: [BaseModel]
  attrs:
    expression: DSLExpression
    context: Dict[str, Any]
    result: Optional[Any]
    error: Optional[str]
    timestamp: datetime

DSLScript:
  doc: "DSL script model."
  bases: [BaseModel]
  attrs:
    name: str
    description: Optional[str]
    statements: List[DSLStatement]
    variables: Dict[str, Any]
    imports: List[str]
    metadata: Dict[str, Any]
    created_at: datetime
    updated_at: datetime

NLPIntent:
  doc: "NLP intent model."
  bases: [BaseModel]
  attrs:
    name: str
    description: str
    examples: List[str]
    entities: Dict[str, str]
    dsl_mapping: str

NLPEntity:
  doc: "NLP entity model."
  bases: [BaseModel]
  attrs:
    name: str
    type: str
    values: List[str]
    patterns: List[str]

NLPModel:
  doc: "NLP model configuration."
  bases: [BaseModel]
  attrs:
    name: str
    type: str
    version: str
    intents: List[NLPIntent]
    entities: List[NLPEntity]
    confidence_threshold: float

DSLContext:
  doc: "DSL execution context model."
  bases: [BaseModel]
  attrs:
    variables: Dict[str, Any]
    functions: Dict[str, Any]
    working_directory: Path
    project_schema: Optional[DSLProjectSchema]
    nlp_model: Optional[NLPModel]
    metadata: Dict[str, Any]
  methods:
    set_variable:
      sig: (name:str, value:Any) -> None
      does: "Set a variable in the context."
      side: "Sets value"
    get_variable:
      sig: (name:str) -> Any
      does: "Get a variable from the context."
    register_function:
      sig: (name:str, func:Any) -> None
      does: "Register a function in the context."

DSLCommandResult:
  doc: "DSL command execution result."
  bases: [BaseModel]
  attrs:
    success: bool
    result: Optional[Any]
    error: Optional[str]
    metadata: Dict[str, Any]
    execution_time: float
    timestamp: datetime

# schema_commands.py | SchemaCommandRegistry, SchemaBasedCommands | 518 lines

imports:
  stdlib: [time, pathlib.Path, typing.{Any,Dict,List,Optional,Union}]
  third_party: [asyncio, nlp.{NLPIntegration,SimpleNLPModel}, schema]

SchemaCommandRegistry:
  doc: "Registry for schema-based DSL commands."
  attrs:
    project_schema: DSLProjectSchema
  methods:
    __init__:
      sig: (project_schema:DSLProjectSchema) -> None
      does: "Initialize command registry with project schema."
    _register_commands:
      sig: () -> None
      does: "Register all commands from project schema."
    get_command:
      sig: (name:str) -> Optional[DSLCommandSchema]
      does: "Get command schema by name or alias."
    list_commands:
      sig: (command_type:Optional[DSLCommandType]=None) -> List[DSLCommandSchema]
      does: "List commands, optionally filtered by type."
    validate_command_call:
      sig: (command_name:str, args:Dict[str,Any]) -> DSLCommandResult
      does: "Validate command call against schema."
    _validate_parameter_type:
      sig: (value:Any, expected_type:DSLDataType) -> bool
      does: "Validate parameter type."
    process_natural_language:
      sig: (text:str) -> DSLCommandResult
      does: "Process natural language input."
    get_suggestions:
      sig: (partial_input:str) -> List[str]
      does: "Get command suggestions."

SchemaBasedCommands:
  doc: "Implementation of schema-based DSL commands."
  attrs:
    context: DSLContext
    registry: SchemaCommandRegistry
  methods:
    __init__:
      sig: (context:DSLContext, registry:SchemaCommandRegistry) -> None
      does: "Initialize schema-based commands."
    execute_command:
      sig: async (command_name:str, args:Dict[str,Any]) -> DSLCommandResult
      does: "Execute a schema-based command."
    _execute_sumd_command:
      sig: async (command:DSLCommandSchema, args:Dict[str,Any]) -> Any
      does: "Execute SUMD command."
    _execute_file_command:
      sig: async (command:DSLCommandSchema, args:Dict[str,Any]) -> Any
      does: "Execute file command."
    _execute_search_command:
      sig: async (command:DSLCommandSchema, args:Dict[str,Any]) -> Any
      does: "Execute search command."
    _execute_utility_command:
      sig: async (command:DSLCommandSchema, args:Dict[str,Any]) -> Any
      does: "Execute utility command."
    _execute_nlp_command:
      sig: async (command:DSLCommandSchema, args:Dict[str,Any]) -> Any
      does: "Execute NLP command."
    _execute_schema_command:
      sig: async (command:DSLCommandSchema, args:Dict[str,Any]) -> Any
      does: "Execute schema command."
    _cmd_sumd_scan:
      sig: async (args:Dict[str,Any]) -> Any
      does: "Scan project and generate SUMD documentation."
    _cmd_sumd_validate:
      sig: async (args:Dict[str,Any]) -> Any
      does: "Validate SUMD document."
    _cmd_sumd_info:
      sig: async (args:Dict[str,Any]) -> Any
      does: "Get SUMD document information."
    _cmd_cat:
      sig: async (args:Dict[str,Any]) -> Any
      does: "Display file contents."
    _cmd_ls:
      sig: async (args:Dict[str,Any]) -> Any
      does: "List directory contents."
    _cmd_edit:
      sig: async (args:Dict[str,Any]) -> Any
      does: "Edit file contents."
      side: "Writes data"
    _cmd_find:
      sig: async (args:Dict[str,Any]) -> Any
      does: "Find files matching pattern."
    _cmd_grep:
      sig: async (args:Dict[str,Any]) -> Any
      does: "Search text in files."
      side: "Modifies list"
    _cmd_echo:
      sig: async (args:Dict[str,Any]) -> Any
      does: "Display message."
    _cmd_pwd:
      sig: async (args:Dict[str,Any]) -> Any
      does: "Print working directory."
    _cmd_cd:
      sig: async (args:Dict[str,Any]) -> Any
      does: "Change directory."
    _cmd_ask:
      sig: async (args:Dict[str,Any]) -> Any
      does: "Ask natural language question."

