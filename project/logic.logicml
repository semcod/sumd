functions:
  _detect_project_type:
    sig: (proj_dir:Path) -> str
    does: "Return a coarse project-type tag (python, node, rust, …) or 'generic'."
  _render_doql_boilerplate:
    sig: (project_name:str, spec:dict[str,str], extra_workflows:dict[str, str] | None=None) -> str
    does: "Render a full app.doql.less boilerplate from a language spec."
    side: "Modifies list"
  _node_framework:
    sig: (deps:set[str]) -> str
    does: "Derive a framework label for a Node project from its dep set."
  _node_spec_from_package_json:
    sig: (pkg_json:dict) -> tuple[dict[str, str], dict[str, str]]
    does: "Return (spec, extra_workflows) tailored to an actual package.json."
    side: "Sets value"
  _build_doql_spec:
    sig: (proj_dir:Path, project_type:str) -> tuple[dict[str, str], dict[str, str]]
    does: "Return (spec, extra_workflows) for the given project type."
  _generate_doql_less:
    sig: (proj_dir:Path, project_name:str, version:str='0.1.0', force:bool=False, project_type:str='python') -> Path | None
    does: "Generate or refresh app.doql.less file."
    side: "Writes data"
  cli:
    sig: () -> None
    does: "SUMD - Structured Unified Markdown Descriptor CLI."
  validate:
    sig: (file:Path) -> None
    does: "Validate a SUMD document."
  export:
    sig: (file:Path, format:str, output:Optional[Path]) -> None
    does: "Export a SUMD document to structured format."
    side: "Writes data"
  info:
    sig: (file:Path) -> None
    does: "Display information about a SUMD document."
  generate:
    sig: (file:Path, format:str, output:Optional[Path]) -> None
    does: "Generate a SUMD document from structured format."
    side: "Modifies list"
  extract:
    sig: (file:Path, section:str) -> None
    does: "Extract content from a SUMD document."
  _is_project_dir:
    sig: (d:Path) -> bool
    does: "Return True if *d* contains any known project-marker file."
  _walk_projects:
    sig: (path:Path, projects:list[Path], max_depth:Any, depth:int) -> None
    does: "Recursively collect project directories (containing any known marker)."
    side: "Modifies list"
  _detect_projects:
    sig: (workspace:Path, max_depth:Any=None) -> list[Path]
    does: "Return sorted list of subdirectories that look like project roots."
  _ensure_venv:
    sig: (tools_dir:Path, venv_dir:Path, tool_list:list[str]) -> None
    does: "Create virtual env and install tools if not already present."
  _tool_bin:
    sig: (bin_dir:Path, name:str) -> Path
    does: "Return path to *name* executable, preferring non-.exe variant."
  _run_one_tool:
    sig: (tool:str, bin_dir:Path, proj_dir:Path, project_output:Path) -> None
    does: "Run a single analysis tool if its arg template is known."
  _run_analysis_tools:
    sig: (proj_dir:Path, tool_list:list[str], skip_tools:set[str] | None=None) -> None
    does: "Install and run code2llm/redup/vallm analysis tools for a project."
    side: "Sets value"
  _export_sumd_json:
    sig: (proj_dir:Path, doc) -> None
    does: "Write sumd.json for a project."
    side: "Writes data"

