# prolog_engine.py | Variable, Term, Rule +3 | 431 lines

imports:
  stdlib: [os, re, subprocess, pathlib.Path, typing]
  third_party: [pyswip]

Variable:
  doc: "Represents a logical variable in our pure Python engine."
  attrs:
    name: str
  methods:
    __init__:
      sig: (name:str) -> None
      does: "creates"
    __repr__:
      sig: () -> str
      does: "repr"
    __eq__:
      sig: (other) -> bool
      does: "eq"
    __hash__:
      sig: () -> int
      does: "hash"

Term:
  doc: "Represents a Prolog term (e.g."
  attrs:
    op: str
  methods:
    __init__:
      sig: (op:str) -> None
      does: "creates"
    __repr__:
      sig: () -> str
      does: "repr"
    __eq__:
      sig: (other) -> bool
      does: "eq"

Rule:
  doc: "Represents a Prolog rule Head :- Body."
  attrs:
    head: Term
    body: Optional[List[Term]]=None
  methods:
    __init__:
      sig: (head:Term, body:Optional[List[Term]]=None) -> None
      does: "creates"
    __repr__:
      sig: () -> str
      does: "repr"

PythonPrologDB:
  doc: "In-memory Prolog database for pure Python execution."
  methods:
    __init__:
      sig: () -> None
      does: "creates"
    add_fact:
      sig: (op:str) -> None
      does: "creates fact"
      side: "Adds element"
    add_rule:
      sig: (head:Term, body:List[Term]) -> None
      does: "creates rule"
      side: "Adds element"
    parse_and_load:
      sig: (prolog_text:str) -> None
      does: "Parses a simple Prolog file into rules/facts."
      side: "Modifies list"

PythonPrologEngine:
  doc: "SLD Resolution Logic Interpreter."
  attrs:
    db: PythonPrologDB
  methods:
    __init__:
      sig: (db:PythonPrologDB) -> None
      does: "creates"
    query:
      sig: (goal_str:str) -> List[Dict[str, Any]]
      does: "retrieves"
      side: "Modifies list"
    _find_vars:
      sig: (term:Any) -> List[Variable]
      does: "retrieves vars"
      side: "Sets value"
    _resolve:
      sig: (goals:List[Any], subst:Dict[Variable,Any]) -> Generator[Dict[Variable, Any], None, None]
      does: "resolve"

HybridPrologEngine:
  doc: "Hybrid Logic Engine delegating queries based on backend a..."
  attrs:
    prolog_file_path: Union[str,Path]
  methods:
    __init__:
      sig: (prolog_file_path:Union[str,Path]) -> None
      does: "creates"
      edge: "error → raise FileNotFoundError"
    query:
      sig: (query_str:str) -> List[Dict[str, Any]]
      does: "Runs query against the best available Prolog backend."
    _query_pyswip:
      sig: (query_str:str) -> List[Dict[str, Any]]
      does: "Executes query using the PySwip wrapper."
      side: "Modifies list"
    _query_subprocess:
      sig: (query_str:str) -> List[Dict[str, Any]]
      does: "Executes query by spawning a swipl process."
      side: "Sets value"
    _query_python:
      sig: (query_str:str) -> List[Dict[str, Any]]
      does: "Pure Python fallback logic query."
    _swipl_executable_exists:
      sig: () -> bool
      does: "swipl executable exists"

functions:
  is_variable:
    sig: (x:Any) -> bool
    does: "checks variable"
  to_term:
    sig: (x:Any) -> Any
    does: "converts term"
  _split_body_terms:
    sig: (body_str:str) -> List[str]
    does: "splits body terms"
    side: "Modifies list"
  unify:
    sig: (x:Any, y:Any, subst:Dict[Variable,Any]) -> Optional[Dict[Variable, Any]]
    does: "Logical unification of x and y under substitution subst."
  resolve_val:
    sig: (x:Any, subst:Dict[Variable,Any]) -> Any
    does: "resolve val"
  deep_resolve:
    sig: (x:Any, subst:Dict[Variable,Any]) -> Any
    does: "deep resolve"
  extend_subst:
    sig: (v:Variable, val:Any, subst:Dict[Variable,Any]) -> Optional[Dict[Variable, Any]]
    does: "extend subst"
  occurs_check:
    sig: (v:Variable, val:Any, subst:Dict[Variable,Any]) -> bool
    does: "occurs check"
  rename_variables:
    sig: (rule:Rule, suffix:int) -> Rule
    does: "Rename variables in rule to avoid collisions in resolution."

